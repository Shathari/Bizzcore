# Isolated test environment — a separate SQLite file so the test suite
# never touches dev.db or its seeded demo data. Values below are dummy/
# fixed (not secrets) since this file only ever runs against a throwaway
# local test database.
NODE_ENV="test"
DATABASE_URL="file:./test.db"

JWT_SECRET="test-jwt-secret-not-for-production-use-0123456789"
JWT_EXPIRES_IN="1h"
COOKIE_NAME="bizzcore_session"

CREDENTIAL_ENCRYPTION_KEY="5215d9a027fe2ecf92460a8b455cef53f5eee1ac08e1196d8b765bc27d36614f"
PII_LOOKUP_HASH_KEY="9c2f6a1e8d4b7053a1c9e6f0b3d8a2c745910eebf3c6a05d7148b9c2e6f0a3d1"

PORT=4001
FRONTEND_ORIGIN="http://localhost:5173"
APP_LOGIN_URL="http://localhost:5173/login"
APP_PUBLIC_URL=""

# AI: left unset by default so tests exercise the "not configured" path.
# The one test that needs a "configured" state stubs process.env directly.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BizzCore <no-reply@bizzcore.example>"

SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

META_GRAPH_API_VERSION="v20.0"
WHATSAPP_GRAPH_API_VERSION="v20.0"

# Short so a "hung connection" test can assert a real timeout within a
# reasonable test duration instead of waiting out the 20s production default.
WEBSITE_API_TIMEOUT_MS="300"
