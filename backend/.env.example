# --- Database ---------------------------------------------------------
# Local dev (SQLite): file:./dev.db
# Production (Postgres): postgresql://user:password@host:5432/bizzcore
DATABASE_URL="file:./dev.db"

# --- Auth ---------------------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
COOKIE_NAME="bizzcore_session"

# 32-byte (64 hex char) key used to AES-256-GCM encrypt IntegrationCredential
# payloads at rest. Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY="replace-with-64-hex-characters"

# 32-byte (64 hex char) key used to HMAC-SHA256 hash Customer PII (phone) for
# exact-match lookup without decrypting — deliberately separate from
# CREDENTIAL_ENCRYPTION_KEY so a lookup-hash leak can't help decrypt anything.
# Generate with: openssl rand -hex 32
PII_LOOKUP_HASH_KEY="replace-with-64-hex-characters"

# --- App ------------------------------------------------------------------
# Set to "production" in real deployments — this is what makes `npm run seed`
# refuse to plant the demo Super Admin / demo tenants (see prisma/seed.ts's
# assertNotProduction). Provision the real Super Admin instead with:
#   npm run super-admin:create -- --email you@yourcompany.com --name "Your Name"
NODE_ENV="development"
# Only set this to "true" for a deliberate non-production demo/sales
# environment where you actually want the seeded demo data. Never set this
# in real production.
ALLOW_DEMO_SEED_IN_PRODUCTION="false"

PORT=4000
FRONTEND_ORIGIN="http://localhost:5173"
APP_LOGIN_URL="http://localhost:5173/login"

# Publicly reachable base URL for this backend, used to build absolute
# media URLs when publishing to Instagram/Facebook (Meta's servers fetch
# the image from this URL — a localhost value only works with mock mode).
# Defaults to http://localhost:$PORT if unset.
APP_PUBLIC_URL=""

# --- AI Marketing Assistant (OpenAI) ---------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Email ------------------------------------------------------------------
# EMAIL_PROVIDER selects which adapter is active: resend | sendgrid |
# postmark | smtp (default). resend/sendgrid/postmark call that provider's
# HTTP API directly (with automatic retries on transient failures — network
# errors, 5xx, 429). Only that provider's own credential env var needs to be
# set; switching providers, or going from mock to live, is an env var
# change, no code change.
#
# EMAIL_FROM must be a sender address whose domain you've verified with your
# provider (SPF/DKIM records added in their dashboard — Resend/SendGrid/
# Postmark/SES all require this before they'll deliver to real inboxes, not
# just their own sandbox/test addresses). Do this once per provider, in
# their dashboard, before going live.
EMAIL_PROVIDER="smtp"
EMAIL_FROM="BizzCore <no-reply@yourdomain.com>"

# Resend — https://resend.com/api-keys (verify your domain at resend.com/domains)
RESEND_API_KEY=""

# SendGrid — https://app.sendgrid.com/settings/api_keys (verify sender identity/domain under Settings > Sender Authentication)
SENDGRID_API_KEY=""

# Postmark — https://account.postmarkapp.com/servers (verify your Sender Signature / domain under that server's Sender Signatures tab)
POSTMARK_SERVER_TOKEN=""

# SMTP (nodemailer) — the default provider, and also the recommended path
# for Amazon SES (SES's own docs favor SMTP for simple integrations over
# hand-rolling AWS SigV4 request signing). Any SMTP-speaking provider works
# here with zero code changes, including the three above if you'd rather use
# their SMTP relay instead of EMAIL_PROVIDER=resend/sendgrid/postmark.
#
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net       SMTP_PORT=587  SMTP_USER=apikey                SMTP_PASSWORD=<SendGrid API key>
#   Resend:    SMTP_HOST=smtp.resend.com         SMTP_PORT=465  SMTP_USER=resend                SMTP_PASSWORD=<Resend API key>
#   SES:       SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587  SMTP_USER=<SES SMTP username>  SMTP_PASSWORD=<SES SMTP password>
#   Postmark:  SMTP_HOST=smtp.postmarkapp.com    SMTP_PORT=587  SMTP_USER=<Server API token>     SMTP_PASSWORD=<same token>
#
# (SES's SMTP username/password are NOT your AWS access key pair — generate
# dedicated SMTP credentials in the SES console, and verify your sending
# domain/identity under SES > Verified identities first.)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BizzCore <no-reply@bizzcore.example>"

# --- Password reset -----------------------------------------------------
PASSWORD_RESET_TOKEN_TTL_MINUTES="60"

# --- SMS ---------------------------------------------------------------
# SMS_PROVIDER selects which adapter is active: twilio | msg91 | textlocal.
# Only that provider's credentials need to be set; switching providers is
# an env var change, no code change.
SMS_PROVIDER="twilio"

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# MSG91 — https://control.msg91.com/app/dashboard (India-focused)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_ROUTE="4"
MSG91_COUNTRY_CODE="91"

# Textlocal — https://control.textlocal.in/settings/ (India/UK-focused)
TEXTLOCAL_API_KEY=""
TEXTLOCAL_SENDER=""

# --- Billing (Razorpay) -------------------------------------------------
# BILLING_PROVIDER selects the active payment gateway adapter (see
# integrations/razorpay.ts) — currently only "razorpay" is implemented, but
# the switch-based dispatch exists so a second provider is a new adapter
# file, not a rewrite of routes/billing.ts.
BILLING_PROVIDER="razorpay"

# Razorpay Dashboard -> Settings -> API Keys. Use TEST mode keys
# (rzp_test_...) until you're ready to go live. KEY_ID is also sent to the
# frontend (Razorpay Checkout requires it client-side) — KEY_SECRET never
# leaves the backend.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Razorpay Dashboard -> Settings -> Webhooks, generated when you register
# the webhook URL. Required for routes/webhooks/razorpay.ts to verify that
# a webhook call genuinely came from Razorpay before trusting it.
RAZORPAY_WEBHOOK_SECRET=""

# --- Meta (Instagram/Facebook Graph API) — platform-level defaults, ------
# per-tenant overrides live encrypted in IntegrationCredential
META_GRAPH_API_VERSION="v20.0"

# --- WhatsApp Business Platform (Cloud API) ---------------------------
WHATSAPP_GRAPH_API_VERSION="v20.0"
